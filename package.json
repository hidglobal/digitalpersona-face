{
  "name": "@digitalpersona/face",
  "globals": [
    "faceSDK",
    "facefinder"
  ],
  "version": "1.0.0",
  "description": "HID DigitalPersona Face API Library",
  "license": "MIT",
  "author": "Andrey Bronnikov <andrey.bronnikov@hidglobal.com>",
  "contributors": [
    "HID Global Corporation"
  ],
  "repository": {
    "type": "git",
    "url": "github:hidglobal/digitalpersona-face"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "keywords": [
    "DigitalPersona",
    "Face",
    "authentication"
  ],
  "files": [
    "dist/",
    "docs/usage/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/@types/index.d.ts",
      "unpkg": "./dist/face.sdk.min.js",
      "browser": "./dist/face.sdk.js"
    },
    "./facefinder": {
      "types": "./dist/@types/facefinder.d.ts",
      "unpkg": "./dist/facefinder.js",
      "browser": "./dist/facefinder.js"
    }
  },
  "-browserslist": [
    "defaults and fully supports es6-module",
    "edge >= 17",
    "not iOS > 0",
    "not Android > 0"
  ],
  "dependencies": {
    "tslib": "^2.7.0"
  },
  "volta": {
    "node": "20.17.0"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc && node esbuild.mjs",
    "publish:pre": "npm publish --tag pre --access=restricted"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/eslint__js": "^8.42.3",
    "esbuild": "^0.25.2",
    "eslint": "^9.9.1",
    "eslint-plugin-compat": "^6.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.4.0"
  }
}
